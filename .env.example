# HobbyHeaven — environment configuration
# Copy this to .env and adjust values before running

# ── Application ──────────────────────────────
APP_PORT=8080

# ── Database ─────────────────────────────────
DB_PORT=5432
DB_NAME=hobbyheaven
DB_USER=hobbyheaven
DB_PASSWORD=changeme         # Change this!

# ── Storage ───────────────────────────────────
# Path on the HOST to mount as /data inside the container.
# Leave blank to use a named Docker volume (default).
# Example: STORAGE_PATH=/mnt/nas/hobbyheaven
STORAGE_PATH=

# ── Auth (optional) ───────────────────────────
# Set to true and run with docker-compose.auth.yml to enable Keycloak
AUTH_ENABLED=false

# Keycloak admin credentials (only used with auth overlay)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme   # Change this!
KEYCLOAK_PORT=9080
KEYCLOAK_REALM=hobbyheaven
KEYCLOAK_CLIENT_ID=hobbyheaven-app
